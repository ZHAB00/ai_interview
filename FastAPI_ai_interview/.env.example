# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=ai_interview

# JWT
SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_MINUTES=43200

# DeepSeek API
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_API_BASE=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash

# Redis (for WebSocket session management)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# App
APP_NAME=AI Interview
APP_PORT=8080
DEBUG=true
DB_ECHO=false
UPLOAD_DIR=uploads
FAISS_DIR=data/faiss
MAX_UPLOAD_SIZE=10485760

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate Limit
RATE_LIMIT_ENABLED=false
RATE_LIMIT=60/minute

# Scoring
PASS_THRESHOLD=60
MAX_QUESTIONS_PER_STAGE=5

# Interview (seconds)
INTERVIEW_MAX_DURATION=2700

# STT/TTS — DashScope (Qwen-ASR-Realtime / Qwen-TTS-Realtime)
# API Key: https://bailian.console.aliyun.com/?tab=model#/api-key
# When DASHSCOPE_API_KEY is set, the dashscope provider is used.
# When empty, falls back to Aliyun NLS (legacy, requires ALIYUN_* keys below).
STT_PROVIDER=dashscope
TTS_PROVIDER=dashscope
DASHSCOPE_API_KEY=

# ASR — Qwen3-ASR-Flash Realtime (WebSocket)
# Model: qwen3-asr-flash-realtime
# Language: zh / en / ja / ko / yue ...
# ASR — Qwen3-ASR-Flash Realtime (WebSocket)
DASHSCOPE_ASR_MODEL=paraformer-realtime-v2
DASHSCOPE_ASR_LANGUAGE=zh

# TTS — Qwen-TTS (MultiModalConversation HTTP REST)
# Models: qwen-tts / qwen3-tts-flash / qwen3-tts-instruct-flash
# Voices: Cherry / Ethan / Jennifer / Ryan / Katerina / Sunny / Dylan ...
# See: https://help.aliyun.com/zh/model-studio/multimodal-timbre-list
DASHSCOPE_TTS_MODEL=qwen3-tts-instruct-flash
DASHSCOPE_TTS_VOICE=Cherry
# language_type: optional, empty = auto-detect (recommended for qwen3-tts series)
DASHSCOPE_TTS_LANGUAGE=

# Legacy NLS (fallback when DASHSCOPE_API_KEY is empty)
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_NLS_APPKEY=

# Alibaba Cloud SMS (register / reset password)
ALIYUN_SMS_SIGN_NAME=速通互联验证码
ALIYUN_SMS_TEMPLATE_REGISTER=100001
ALIYUN_SMS_TEMPLATE_LOGIN=100001
ALIYUN_SMS_TEMPLATE_RESET_PASSWORD=100001
ALIYUN_SMS_CODE_LENGTH=6
ALIYUN_SMS_VALID_SECONDS=300
ALIYUN_SMS_RETRY_SECONDS=60
ALIYUN_SMS_MAX_DAILY=10

# Object Storage
OSS_ENDPOINT=
OSS_BUCKET=
OSS_ACCESS_KEY=
OSS_SECRET_KEY=

# Web Search
SEARCH_API_KEY=
SEARCH_PROVIDER=serper

# Logging
# LOG_FORMAT: "plain" for human-readable console logs, "json" for structured (production)
# LOG_LEVEL: default level for all loggers
# LOG_LEVEL_APP: override for app.* loggers (set to DEBUG in dev for call traces)
# LOG_LEVEL_ACCESS: override for app.access (HTTP request/response logging)
#   Set to CRITICAL to disable access logs, or DEBUG to see them
# LOG_LEVEL_*: suppress noisy third-party libraries to WARNING
LOG_FORMAT=plain
LOG_LEVEL=INFO
LOG_LEVEL_APP=DEBUG
LOG_LEVEL_ACCESS=INFO
LOG_LEVEL_WATCHFILES=WARNING
LOG_LEVEL_UVCORN=WARNING
LOG_LEVEL_HTTPX=WARNING
